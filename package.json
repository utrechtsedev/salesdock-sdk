{
  "name": "salesdock",
  "version": "0.1.1",
  "description": "Universal, fully-typed TypeScript SDK for the Salesdock API. Runs on Node.js, Cloudflare Workers, Deno, Bun, and the browser.",
  "keywords": [
    "salesdock",
    "sdk",
    "api",
    "client",
    "typescript",
    "cloudflare-workers",
    "serverless",
    "energy",
    "telecom",
    "crm"
  ],
  "license": "AGPL-3.0-or-later",
  "author": {
    "name": "Risker",
    "url": "https://risker.nl"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/utrechtsedev/salesdock-sdk.git"
  },
  "homepage": "https://github.com/utrechtsedev/salesdock-sdk#readme",
  "bugs": {
    "url": "https://github.com/utrechtsedev/salesdock-sdk/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "!dist/**/*.map",
    "README.md",
    "LICENSE",
    "COMMERCIAL-LICENSE.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.3.3",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
